generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Song {
  id           String   @id @default(cuid())
  userId       String
  title        String
  artist       String
  originalKey  String
  content      String
  capo         Int      @default(0)
  transposeBy  Int      @default(0)
  preferredKey String?
  youtubeId    String?
  chordMap     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}
